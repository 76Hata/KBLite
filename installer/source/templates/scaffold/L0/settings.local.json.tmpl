{
  "mcpServers": {
    "kblite-tasks": {
      "command": "python",
      "args": ["{{KBLITE_INSTALL_DIR}}/mcp_tasks.py"]
    }
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "TodoWrite",
        "hooks": [
          {
            "type": "command",
            "command": "python {{KBLITE_INSTALL_DIR}}/scripts/sync_todowrite.py"
          }
        ]
      },
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python {{KBLITE_INSTALL_DIR}}/scripts/perm_request_hook.py"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python {{KBLITE_INSTALL_DIR}}/scripts/session_start_banner.py"
          }
        ]
      }
    ]
  }
}
